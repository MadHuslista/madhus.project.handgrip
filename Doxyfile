# =============================================================================
# Doxyfile.template — Handgrip Project
# Generated by: doxygen-document skill
# Usage: copy to repo root as "Doxyfile", then run `doxygen Doxyfile`
# Doxygen manual: https://www.doxygen.nl/manual/config.html
# =============================================================================

#---------------------------------------------------------------------------
# Project identity
#---------------------------------------------------------------------------
PROJECT_NAME           = "Handgrip"
PROJECT_NUMBER         =
PROJECT_BRIEF          = "Handgrip acquisition, calibration and analysis system"
OUTPUT_DIRECTORY       = .doxygen

#---------------------------------------------------------------------------
# Input sources
# Add or remove library paths as the project grows.
# Start with one library and expand incrementally.
#---------------------------------------------------------------------------
INPUT                  = LSL_Bridge \
                         LSL_Viewer \
                         Handgrip_Analysis \
                         Handgrip_Calibration \
                         RS485_GUI \
                         Handgrip_Firmware/Core

# Recurse into subdirectories
RECURSIVE              = YES

# File extensions to process
FILE_PATTERNS          = *.py \
                         *.h \
                         *.c \
                         *.cpp

# Directories and patterns to exclude
EXCLUDE_PATTERNS       = */.venv/* \
                         */build/* \
                         */__pycache__/* \
                         */node_modules/*

#---------------------------------------------------------------------------
# Extraction behaviour
#---------------------------------------------------------------------------
# Document ALL entities, even those without docstrings.
# Set to NO once full docstring coverage is achieved.
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES

#---------------------------------------------------------------------------
# Language-specific settings
#---------------------------------------------------------------------------
# Required for correct Python output (Java-like structure)
OPTIMIZE_OUTPUT_JAVA   = YES

# Force ## comment style; ignore """ triple-quoted docstrings
PYTHON_DOCSTRING       = NO

#---------------------------------------------------------------------------
# Output formats — HTML only
#---------------------------------------------------------------------------
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_DYNAMIC_SECTIONS  = YES

GENERATE_LATEX         = NO
GENERATE_MAN           = NO
GENERATE_RTF           = NO
GENERATE_XML           = NO

#---------------------------------------------------------------------------
# Graphs and diagrams (requires Graphviz/dot)
# Install: apt install graphviz  |  brew install graphviz
#---------------------------------------------------------------------------
HAVE_DOT               = YES
DOT_NUM_THREADS        = 0

CALL_GRAPH             = YES
CALLER_GRAPH           = YES
INCLUDE_GRAPH          = YES
INCLUDED_BY_GRAPH      = YES

# Limit graph depth to keep diagrams readable
MAX_DOT_GRAPH_DEPTH    = 4

#---------------------------------------------------------------------------
# Source browsing
#---------------------------------------------------------------------------
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = NO

#---------------------------------------------------------------------------
# Build quality
#---------------------------------------------------------------------------
# Emit a warning for every entity missing documentation.
# Useful during the initial documentation pass.
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = YES

#---------------------------------------------------------------------------
# Advanced: search and cross-references
#---------------------------------------------------------------------------
SEARCHENGINE           = YES
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

#---------------------------------------------------------------------------
# Notes for the skill to validate
# The skill checks these critical settings before reporting Doxyfile mismatches:
#   - OPTIMIZE_OUTPUT_JAVA  (must be YES for Python)
#   - PYTHON_DOCSTRING      (must be NO to enable ## comment style)
#   - EXTRACT_ALL           (YES during documentation pass)
#   - FILE_PATTERNS         (must include *.py and *.h / *.c)
#   - INPUT                 (must include the directories being documented)
#   - HAVE_DOT              (YES if diagrams are expected)
#---------------------------------------------------------------------------
